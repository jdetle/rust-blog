# Ignore file scoped to Dockerfile.frontend — Docker/ACR resolves this
# automatically when building with --file Dockerfile.frontend.
# Keeps all Next.js source (app/, components/, lib/, public/, posts/)
# and excludes Rust artifacts and other build noise.

# Rust build output
target/

# Generated Next.js output and deps (rebuilt inside the image)
.next/
node_modules/

# Git internals
.git/

# Secrets — never send to the build context
.env
.env.*

# CI / tooling / docs (not needed for the Next.js build)
.github/
.cursor/
.claude/
docs/
scripts/
e2e/
tests/

# Rust source (not needed for the frontend build)
src/
benches/
migrations/

# Rust project files
Cargo.toml
Cargo.lock

# The Rust Dockerfile (avoid confusion)
Dockerfile
