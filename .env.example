NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=XXXXXXXXXX
# Required for client-side PostHog (instrumentation-client + /who-are-you). Without it, init is a no-op.
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=jdetle.com
NEXT_PUBLIC_META_PIXEL_ID=169560873691070
NEXT_PUBLIC_SITE_URL=https://jdetle.com

# PostHog Personal API Key (phx_...) — for /api/analytics/my-events to fetch events by distinct_id
POSTHOG_PERSONAL_API_KEY=
# PostHog Project ID (numeric project id for Events API path; rust ingestion default "1")
POSTHOG_PROJECT_ID=
# Clarity Data Export API (Bearer) — same token as Rust `pull_clarity`; for CI read checks
CLARITY_EXPORT_TOKEN=
# Optional: override Clarity Data Export URL (default: Microsoft Clarity project-live-insights)
CLARITY_EXPORT_URL=

# Plausible Stats API (read-only aggregate) — optional; for CI / local verify
PLAUSIBLE_API_KEY=
# Site id for Stats API (often same as NEXT_PUBLIC_PLAUSIBLE_DOMAIN)
PLAUSIBLE_SITE_ID=

# Analytics-ingestion: provider API keys for collecting fingerprinted user data
# Vercel Drain: configure drain destination to POST to https://<ANALYTICS_API_URL>/api/drain/vercel
# Vercel: Token for API access (drain config, future pull). Drains PUSH to our /api/events.
VERCEL_TOKEN=
# Google: Path to service account JSON for BigQuery (GA4 export). Enables per-user queries.
GOOGLE_APPLICATION_CREDENTIALS=
# Meta: Conversions API access token. No pull API — used to send server-side events.
META_ACCESS_TOKEN=

# Rust analytics ingestion (Container App / local). Next.js API routes proxy here
# (user-profile, generate-avatar, user-events). Prefer this name — server-only.
ANALYTICS_API_URL=http://localhost:8080
# Legacy alias if you already set it in Vercel (same value as ANALYTICS_API_URL):
# NEXT_PUBLIC_ANALYTICS_API_URL=

# Mock analytics seeding (seed-mock-analytics binary)
SEED_DAYS_BACK=14

# LLM summarization (analytics-ingestion)
ANTHROPIC_API_KEY=
SUMMARIZE_ENABLED=true
SUMMARIZE_SESSIONS_PER_CYCLE=5
